{% liquid
  assign featured_product = section.settings.featured_product
  if featured_product == blank
    assign featured_product = all_products['becoming-a-great-dad']
  endif
%}

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">The digital guide library</p>
    <h1>GuideVault</h1>
    <p class="hero-text">
      A growing vault of practical PDF guides across life, money, habits,
      family, career, wellness, and skills. Fast to read, easy to use, and made
      for people who want clear next steps.
    </p>
    <div class="hero-actions">
      {% if featured_product != blank %}
        <a class="button primary" href="{{ featured_product.url }}">Explore latest guide</a>
      {% else %}
        <a class="button primary" href="{{ routes.all_products_collection_url }}">Shop guides</a>
      {% endif %}
      <a class="button secondary" href="#topics">Browse topics</a>
    </div>
  </div>

  <div class="hero-product" aria-label="Featured guide preview">
    <div class="product-orbit"></div>
    <div class="topic-tile tile-career">Career</div>
    <div class="topic-tile tile-money">Money</div>
    <div class="topic-tile tile-habits">Habits</div>
    <div class="vault-visual" aria-hidden="true">
      <span>PDF</span>
      <strong>Guides</strong>
      <em>Life / Money / Skills / Wellness</em>
    </div>
    <div class="hero-badge">
      <strong>Instant PDF</strong>
      <span>Read on any device</span>
    </div>
  </div>
</section>

<section class="trust-strip" aria-label="Store benefits">
  <span>Instant delivery</span>
  <span>Multi-topic library</span>
  <span>Mobile friendly PDFs</span>
  <span>Lifetime access</span>
</section>

<section class="section topic-section" id="topics">
  <div class="section-heading">
    <p class="eyebrow">Guide categories</p>
    <h2>One store, many useful paths</h2>
    <p>
      GuideVault is built to expand into a full PDF library. Today's first
      guide is one shelf in a wider collection of focused, practical resources.
    </p>
  </div>

  <div class="topic-grid">
    <div class="topic-card accent-green">
      <span>Life</span>
      <h3>Everyday decisions</h3>
      <p>Guides for home, routines, planning, and personal milestones.</p>
    </div>
    <div class="topic-card accent-blue">
      <span>Money</span>
      <h3>Simple finance</h3>
      <p>Practical resources for budgeting, saving, and smarter choices.</p>
    </div>
    <div class="topic-card accent-gold">
      <span>Skills</span>
      <h3>Learn faster</h3>
      <p>Focused PDFs for career growth, productivity, and new abilities.</p>
    </div>
    <div class="topic-card accent-coral">
      <span>Wellness</span>
      <h3>Better habits</h3>
      <p>Clear steps for routines, mindset, energy, and day-to-day balance.</p>
    </div>
  </div>
</section>

<section class="section" id="guides">
  <div class="section-heading">
    <p class="eyebrow">Latest drop</p>
    <h2>The first guide in the vault</h2>
    <p>
      This is the first product available today. More guides can be added here
      as the store expands into new topics.
    </p>
  </div>

  <article class="product-feature">
    <div class="product-media">
      <div class="product-media-label">Latest PDF</div>
      {% if featured_product.featured_image %}
        {{ featured_product.featured_image | image_url: width: 760 | image_tag: alt: featured_product.title, loading: 'lazy' }}
      {% else %}
        <img src="{{ 'becoming-a-great-dad.png' | asset_url }}" alt="Becoming a Great Dad guide cover" loading="lazy">
      {% endif %}
      <div class="product-preview-note">
        <strong>Digital download</strong>
        <span>PDF format</span>
      </div>
    </div>

    <div class="product-info">
      <div class="product-meta">
        <span>PDF guide</span>
        <span>Instant access</span>
        <span>New release</span>
      </div>

      {% if featured_product != blank %}
        <h3>{{ featured_product.title }}</h3>
        <div class="product-description">
          {{ featured_product.description | default: 'A practical digital guide with clear sections, useful takeaways, and a format designed for quick reading.' }}
        </div>
      {% else %}
        <h3>Becoming a Great Dad</h3>
        <p>A practical digital guide with clear sections, useful takeaways, and a format designed for quick reading.</p>
      {% endif %}

      <ul class="feature-list" aria-label="Guide highlights">
        <li>Practical PDF format designed for quick reading</li>
        <li>Clear sections with useful takeaways and checklists</li>
        <li>Instant digital access after purchase</li>
        <li>Readable on phone, tablet, laptop, or desktop</li>
      </ul>

      <div class="product-stats" aria-label="Product benefits">
        <div>
          <strong>PDF</strong>
          <span>Format</span>
        </div>
        <div>
          <strong>24/7</strong>
          <span>Access</span>
        </div>
        <div>
          <strong>Any</strong>
          <span>Device</span>
        </div>
      </div>

      <div class="purchase-row">
        <div>
          {% if featured_product != blank %}
            <span class="price">{{ featured_product.price | money }}</span>
          {% else %}
            <span class="price">$19</span>
          {% endif %}
          <span class="price-note">Instant digital download</span>
        </div>

        {% if featured_product.available and featured_product.selected_or_first_available_variant %}
          {% form 'product', featured_product, class: 'product-form' %}
            <input type="hidden" name="id" value="{{ featured_product.selected_or_first_available_variant.id }}">
            <button class="button primary" type="submit">Add to cart</button>
          {% endform %}
        {% elsif featured_product != blank %}
          <a class="button primary" href="{{ featured_product.url }}">View product</a>
        {% else %}
          <a class="button primary" href="{{ routes.all_products_collection_url }}">View guides</a>
        {% endif %}
      </div>
    </div>
  </article>
</section>

<section class="section product-library" id="library">
  <div class="section-heading">
    <p class="eyebrow">All guides</p>
    <h2>The growing vault</h2>
    <p>
      Every published PDF product in your Shopify catalog appears here
      automatically, so new guides can be added without changing the theme.
    </p>
  </div>

  <div class="library-grid">
    {% for product in collections.all.products limit: 12 %}
      <article class="library-card">
        <a class="library-media" href="{{ product.url }}" aria-label="View {{ product.title | escape }}">
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 620 | image_tag: alt: product.title, loading: 'lazy' }}
          {% else %}
            <img src="{{ 'becoming-a-great-dad.png' | asset_url }}" alt="{{ product.title | escape }}" loading="lazy">
          {% endif %}
        </a>

        <div class="library-info">
          <div class="product-meta">
            <span>PDF guide</span>
            {% if product.available %}
              <span>Available</span>
            {% else %}
              <span>Sold out</span>
            {% endif %}
          </div>
          <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <p>{{ product.description | strip_html | truncate: 120 }}</p>
          <div class="library-footer">
            <strong>{{ product.price | money }}</strong>
            <a class="button secondary compact" href="{{ product.url }}">View guide</a>
          </div>
        </div>
      </article>
    {% else %}
      <div class="empty-library">
        <h3>No guides are published yet</h3>
        <p>Publish products to the Online Store channel and they will appear here.</p>
      </div>
    {% endfor %}
  </div>
</section>

<section class="section split" id="inside">
  <div>
    <p class="eyebrow">How guides are built</p>
    <h2>Designed to be useful quickly</h2>
    <p>
      Every GuideVault PDF should feel polished, focused, and immediately
      usable, whatever the topic is.
    </p>
  </div>

  <div class="inside-grid">
    <div class="inside-card">
      <span>01</span>
      <h3>Understand</h3>
      <p>Get the core idea without digging through long, messy content.</p>
    </div>
    <div class="inside-card">
      <span>02</span>
      <h3>Apply</h3>
      <p>Turn the topic into simple actions, checklists, and decisions.</p>
    </div>
    <div class="inside-card">
      <span>03</span>
      <h3>Save</h3>
      <p>Keep the PDF on your device and revisit it whenever it helps.</p>
    </div>
    <div class="inside-card">
      <span>04</span>
      <h3>Expand</h3>
      <p>Build your own library as new GuideVault topics are released.</p>
    </div>
  </div>
</section>

<section class="section visual-band">
  <div>
    <p class="eyebrow">Built for digital reading</p>
    <h2>A premium home for practical PDFs</h2>
    <p>
      The store is ready to grow beyond one niche: new guides, new categories,
      and a cleaner way to buy focused knowledge online.
    </p>
  </div>
  {% if featured_product != blank %}
    <a class="button dark" href="{{ featured_product.url }}">Get the guide</a>
  {% else %}
    <a class="button dark" href="{{ routes.all_products_collection_url }}">Get the guide</a>
  {% endif %}
</section>

{% schema %}
{
  "name": "GuideVault home",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    }
  ],
  "presets": [
    {
      "name": "GuideVault home"
    }
  ]
}
{% endschema %}
